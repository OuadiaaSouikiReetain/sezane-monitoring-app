VITE_API_URL=http://localhost:8000/api
VITE_APP_ENV=development

# Salesforce Marketing Cloud (SFMC) — Sandbox / Test instance
# WARNING: VITE_ variables are bundled into browser JS.
# For production, proxy these calls through your backend instead.
VITE_SFMC_CLIENT_ID=your_client_id_here
VITE_SFMC_CLIENT_SECRET=your_client_secret_here
VITE_SFMC_AUTH_BASE_URI=https://XXXXX.auth.marketingcloudapis.com
VITE_SFMC_REST_BASE_URI=https://XXXXX.rest.marketingcloudapis.com
# Optional: MID of the Business Unit to authenticate against
VITE_SFMC_ACCOUNT_ID=
