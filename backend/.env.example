# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production-use-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.development

# ─── SFMC Credentials (côté serveur uniquement — ne jamais exposer au frontend)
SFMC_CLIENT_ID=your_client_id_here
SFMC_CLIENT_SECRET=your_client_secret_here
SFMC_AUTH_BASE_URI=https://XXXXX.auth.marketingcloudapis.com
SFMC_REST_BASE_URI=https://XXXXX.rest.marketingcloudapis.com
SFMC_ACCOUNT_ID=

# ─── Redis (Celery broker) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Notifications ────────────────────────────────────────────────────────────
SLACK_DEFAULT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
ALERT_FROM_EMAIL=monitoring@company.com

# ─── Production uniquement ────────────────────────────────────────────────────
# ALLOWED_HOSTS=monitoring.company.com,api.monitoring.company.com
# CORS_ALLOWED_ORIGINS=https://monitoring.company.com
# DB_NAME=monitoring_db
# DB_USER=monitoring_user
# DB_PASSWORD=secure_password
# DB_HOST=localhost
# DB_PORT=5432
